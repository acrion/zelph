#!/usr/bin/env zelph
# dev_scripts/paper/s2_roundtrips.zph
# Compile/reduce round trips for exp and ln in one session.
.import arithmetic
.import symbolic-core
.import eml
x ~ symvar

:emlcompile (exp of x)
.run
(:emlcompile (exp of x)) = F
(:emlcompile (exp of x)) = F

:simplify (x eml &1)
.run
(:simplify (x eml &1)) = X
(:simplify (x eml &1)) = X

:emlcompile (ln of x)
.run
(:emlcompile (ln of x)) = F
(:emlcompile (ln of x)) = F

:simplify (&1 eml ((&1 eml x) eml &1))
.run
(:simplify (&1 eml ((&1 eml x) eml &1))) = X
(:simplify (&1 eml ((&1 eml x) eml &1))) = X
