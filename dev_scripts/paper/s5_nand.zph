#!/usr/bin/env zelph
# dev_scripts/paper/s5_nand.zph
# Discrete Sheffer case study: arithmetic and number theory from one gate.
.import binary-nand-arithmetic
(1 nand 1) out X
(0 nand 1) out X
((1 d+ 1) tci 1) co X
(&12 * &34) = X
(&12 * &34) = X
.import primes-naf
(:testprime &13) = X
(:testprime &13) = X
