#!/usr/bin/env zelph
# dev_scripts/paper/s3_macro_chain.zph
# Macro-chain compilation (-,+,*,/) and the Table-S2 witness recovery:
# simplifying the compiled x - y tree yields eml(ln x, exp y).
.import arithmetic
.import symbolic-core
.import eml
x ~ symvar
y ~ symvar

:emlcompile (x - y)
.run
(:emlcompile (x - y)) = F
(:emlcompile (x - y)) = F

:emlcompile (x + y)
.run
(:emlcompile (x + y)) = F

:emlcompile (x * y)
.run
(:emlcompile (x * y)) = F

:emlcompile (x / y)
.run
(:emlcompile (x / y)) = F

:simplify ((&1 eml ((&1 eml x) eml &1)) eml (y eml &1))
.run
(:simplify ((&1 eml ((&1 eml x) eml &1)) eml (y eml &1))) = X
(:simplify ((&1 eml ((&1 eml x) eml &1)) eml (y eml &1))) = X
