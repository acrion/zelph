#!/usr/bin/env zelph
# dev_scripts/paper/s6_knowledge_folding.zph
# Computed folding (cascaded), declared folding, and composed partiality.
.import arithmetic
.import symbolic-core
x ~ symvar

:simplify ((&2 + &3) * (&4 + &6))
.run
(:simplify ((&2 + &3) * (&4 + &6))) = X
(:simplify ((&2 + &3) * (&4 + &6))) = X

a ~ symconst
b ~ symconst
c ~ symconst
(a + b) = c
:simplify (a + b)
.run
(:simplify (a + b)) = X
(:simplify (a + b)) = X

:simplify (&5 / &0)
.run
(:simplify (&5 / &0)) = X
(:simplify (&5 / &0)) = X
