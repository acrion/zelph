#!/usr/bin/env zelph
# dev_scripts/paper/s1_eq5_derivation.zph
# Flagship artifact: zelph derives paper Eq. (5) with full provenance.
.import arithmetic
.import symbolic-core
.import eml
x ~ symvar
:simplify (&1 eml ((&1 eml x) eml &1))
.run
(:simplify (&1 eml ((&1 eml x) eml &1))) = X
(:simplify (&1 eml ((&1 eml x) eml &1))) = X
