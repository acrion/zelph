[
  {
    "label": "CMake Configure (Debug)",
    "command": "cmake",
    "args": ["--fresh", "-S", ".", "-B", "build-debug", "-DCMAKE_BUILD_TYPE=Debug"],
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "CMake Configure (Release)",
    "command": "cmake",
    "args": ["--fresh", "-S", ".", "-B", "build-release", "-DCMAKE_BUILD_TYPE=Release"],
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "CMake Build (Release)",
    "command": "cmake",
    "args": ["--build", "build-release", "--parallel"],
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "CMake Rebuild (Release)",
    "command": "cmake",
    "args": ["--build", "build-release", "--clean-first", "--parallel"],
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "CTest (Release)",
    "command": "ctest",
    "args": ["--test-dir", "build-release", "--output-on-failure", "--parallel"],
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "cppcheck (full)",
    "command": "bash",
    "args": ["-c", "'cppcheck --project=compile_commands.json --enable=all --suppress=unmatchedSuppression --check-level=exhaustive --inline-suppr --suppress=missingIncludeSystem --suppress=*:*/_deps/* --std=c++20 --inconclusive -i build-debug -i build-release -j$(nproc) 2>&1 | tee build-debug/cppcheck.log'"],
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "Clang Static Analyzer (HTML report)",
    "command": "bash",
    "args": ["-c", "'analyze-build --cdb compile_commands.json --output build-debug/csa-report --status-bugs --exclude build-debug --exclude build-release 2>&1; echo \"Report: build-debug/csa-report\"'"],
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
]
