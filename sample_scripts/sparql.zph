# sparql.zph - SPARQL subset support for zelph
#
# Usage after importing this script:
#
#   sparql
#   SELECT ?x ?y WHERE {
#     ?x wdt:P31 wd:Q5 .
#     ?x wdt:P279+ ?y .
#   }
#   <blank line>
#
# A blank line asks the handler whether the query is complete (veto
# protocol): while no SELECT has been seen or braces are unbalanced, the
# blank line becomes part of the query and accumulation continues - so
# pretty-printed queries containing blank lines can be pasted verbatim.
# Two consecutive blank lines force dispatch (escape hatch for broken
# input).#
# Supported subset:
#   - SELECT [DISTINCT] ?vars... | *  with WHERE { ... }
#   - Basic Graph Patterns (triple blocks, '.' separated, ';' and ',' lists)
#   - Property paths: p+ p* and sequences p1/p2/p3 (each element may carry + or *)
#   - OPTIONAL { ... }, MINUS { ... }, UNION of group graph patterns
#   - FILTER with comparison of str(?v) / lang(?v) / vars / literals,
#     using = != < > <= >=
#   - Subqueries: { SELECT ... { ... } }
#   - GROUP BY ?v with (COUNT(?v) AS ?alias)
#   - ORDER BY ASC(?v) / DESC(?v) / ?v
#   - LIMIT n, DISTINCT
#   - PREFIX declarations are parsed; well-known Wikidata prefixes
#     (wd:, wdt:, p:, pq:, ps:, ...) strip to bare Q/P IDs, since zelph's
#     wikidata language uses plain IDs as node names.
#
# Explicitly out of scope (rejected with an error message):
#   BIND, VALUES, SERVICE, CONSTRUCT/ASK/DESCRIBE, EXISTS/NOT EXISTS, GRAPH,
#   HAVING, aggregations other than COUNT, arbitrary FILTER expressions.

%
# ============================================================
# 0. Optional phase profiling
# ============================================================
# Enable from the REPL with:   %(set sparql-profile true)
# Disable with:                %(set sparql-profile false)
# Every evaluation phase that takes longer than 1 ms then prints a line
# like  [sparql  4.231s] minus-join 3214x2987  (durations and row counts).
# Output goes to stdout directly (Janet print), which is fine in the REPL.
(var sparql-profile false)

(defn prof
  "Run f, printing its duration with the given label when profiling is on."
  [label f]
  (if sparql-profile
    (do
      (def t0 (os/clock :monotonic))
      (def r (f))
      (def dt (- (os/clock :monotonic) t0))
      (when (> dt 0.001)
        (print (string/format "[sparql %7.3fs] %s" dt label)))
      r)
    (f)))

# ============================================================
# 1. Native closure wrappers (with per-query cache)
# ============================================================

# Thin wrappers around the native transitive closure in the zelph core
# (Zelph::transitive_targets / Zelph::transitive_sources, exposed as
# zelph/closure and zelph/closure-sources).
# include-start true => reflexive closure (SPARQL `*`); false => one-or-more
# (SPARQL `+`), where the start node is still included when it is reachable
# from itself via a cycle of one or more steps.
#
# Closures are memoized for the duration of one query (the cache is cleared
# in sparql-handler before evaluation). Within a query the graph only gains
# pattern facts with variable endpoints, which the native closure ignores
# (is_var nodes are excluded), so reuse is safe. This lets a MINUS group
# that repeats the closures of the outer pattern - the shape of the
# disjointness culprit queries - get them for free.
(def closure-cache @{})

(defn zelph-closure [start predicate include-start]
  (def key [:fwd start predicate include-start])
  (or (get closure-cache key)
      (let [arr (prof (string "closure fwd " (or (zelph/name start "wikidata") start))
                      (fn [] (zelph/closure start predicate include-start)))]
        (put closure-cache key arr)
        arr)))

(defn zelph-closure-sources [target predicate include-target]
  (def key [:bwd target predicate include-target])
  (or (get closure-cache key)
      (let [arr (prof (string "closure bwd " (or (zelph/name target "wikidata") target))
                      (fn [] (zelph/closure-sources target predicate include-target)))]
        (put closure-cache key arr)
        arr)))

# ============================================================
# 2. Prefix handling
# ============================================================
# zelph's wikidata language names direct-triple nodes with bare IDs
# (Q5, P31). The reified statement layer created by .wikidata-qualifiers
# keeps the RDF prefix as part of the node name (p:P2738, ps:P2738,
# pq:P11260, wikibase:rank), so that e.g. wdt:P279+ closures can never
# leak into statement nodes. Each SPARQL prefix therefore maps to the
# node-name prefix used in the wikidata language; all of these resolve
# explicitly in the "wikidata" language, independent of the REPL's .lang.
(def wikidata-prefixes
  {"wd" "" "wdt" ""
   "p" "p:" "pq" "pq:" "ps" "ps:"
   "psv" "psv:" "pqv" "pqv:" "wdtn" "wdtn:"
   "wikibase" "wikibase:"})

# Full-IRI prefixes map the same way. Order matters: the more specific
# prop/direct, prop/qualifier and prop/statement prefixes must be checked
# before the generic prop/ prefix.
(def wd-iri-prefixes
  [["http://www.wikidata.org/entity/" ""]
   ["http://www.wikidata.org/prop/direct/" ""]
   ["http://www.wikidata.org/prop/qualifier/" "pq:"]
   ["http://www.wikidata.org/prop/statement/" "ps:"]
   ["http://www.wikidata.org/prop/" "p:"]
   ["http://wikiba.se/ontology#" "wikibase:"]])

# ============================================================
# 3. PEG grammar for the SPARQL subset
# ============================================================
(def sparql-grammar
  ~{:ws (set " \t\r\n")
    :s* (any (choice :ws :comment))
    :s+ (some (choice :ws :comment))
    :comment (* "#" (any (if-not "\n" 1)) (choice "\n" -1))

    :ncname (some (choice (range "az") (range "AZ") (range "09") (set "_-")))

    # IRIs and prefixed names
    :iri-ref (group (* (constant :iri) "<" (capture (some (if-not ">" 1))) ">"))
    # The local part may be empty: example query (2) declares prefixes for
    # full entity IRIs and references them as bare "violated_1:".
    :pname (group (* (constant :pname)
                     (capture (any (choice (range "az") (range "AZ") (range "09") "_")))
                     ":"
                     (capture (any (choice (range "az") (range "AZ") (range "09") (set "_-"))))))

    # Variables
    :var (group (* (constant :var) (choice "?" "$") (capture :ncname)))

    # Literals
    :string-lit (choice
                  (* "\"" (capture (any (if-not "\"" 1))) "\"")
                  (* "'" (capture (any (if-not "'" 1))) "'"))
    :lang-tag (* "@" (capture :ncname))
    :literal (group (* (constant :literal) :string-lit (? :lang-tag)))
    :number (group (* (constant :number)
                      (capture (* (? "-") (some (range "09"))
                                  (? (* "." (some (range "09"))))))))

    # Path element: iri/pname optionally followed by + or *
    :path-mod (capture (set "+*"))
    :path-elem (group (* (constant :pelem) (choice :iri-ref :pname) (? :path-mod)))
    :path (group (* (constant :path) :path-elem (any (* "/" :path-elem))))

    # Keywords (accept upper- and lowercase)
    :kw-select (choice "SELECT" "select")
    :kw-distinct (choice "DISTINCT" "distinct")
    :kw-where (choice "WHERE" "where")
    :kw-optional (choice "OPTIONAL" "optional")
    :kw-minus (choice "MINUS" "minus")
    :kw-union (choice "UNION" "union")
    :kw-filter (choice "FILTER" "filter")
    :kw-prefix (choice "PREFIX" "prefix")
    :kw-group (choice "GROUP" "group")
    :kw-order (choice "ORDER" "order")
    :kw-by (choice "BY" "by")
    :kw-limit (choice "LIMIT" "limit")
    :kw-as (choice "AS" "as")
    :kw-count (choice "COUNT" "count")
    :kw-asc (choice "ASC" "asc")
    :kw-desc (choice "DESC" "desc")

    # Prologue
    :prefix-decl (group (* (constant :prefix) :kw-prefix :s+
                           (capture (any (choice (range "az") (range "AZ")
                                                 (range "09") "_")))
                           ":" :s* "<" (capture (some (if-not ">" 1))) ">"))

    # Terms usable in subject/object position
    :term (choice :var :iri-ref :pname :literal :number)

    # Predicate position: variable or path (a path covers a single iri too)
    :verb (choice :var :path)

    # Object list: obj ("," obj)*
    :object-list (group (* (constant :objs) :term (any (* :s* "," :s* :term))))

    # Property list: verb objlist (";" verb objlist)*
    :prop-pair (group (* (constant :pp) :verb :s+ :object-list))
    :prop-list (* :prop-pair (any (* :s* ";" :s* :prop-pair)))

    # Triples block entry
    :triples (group (* (constant :triples) :term :s+ :prop-list))

    # FILTER expression (restricted to a single comparison)
    :func-call (group (* (constant :func)
                         (capture (choice "str" "STR" "lang" "LANG"))
                         :s* "(" :s* :var :s* ")"))
    :cmp-op (capture (choice "<=" ">=" "!=" "=" "<" ">"))
    :filter-operand (choice :func-call :var :literal :number :iri-ref :pname)
    :filter-expr (group (* (constant :cmp) :filter-operand :s* :cmp-op
                           :s* :filter-operand))
    # Opening and closing parens may be nested, e.g. FILTER ( ( a < b ) ).
    # Balance is not enforced (acceptable for this subset).
    :filter (group (* (constant :filter) :kw-filter :s* (some (* "(" :s*))
                      :filter-expr :s* (some (* ")" :s*))))

    # Graph patterns
    :group-pattern (group (* (constant :group) "{" :s*
                             (any (* :pattern-elem :s* (? (* "." :s*)))) "}"))

    :union-pattern (group (* (constant :union)
                             :group-pattern
                             (some (* :s* :kw-union :s* :group-pattern))))

    :optional-pattern (group (* (constant :optional) :kw-optional :s*
                                (choice :union-pattern :group-pattern)))
    :minus-pattern (group (* (constant :minus) :kw-minus :s* :group-pattern))

    :subquery (group (* (constant :subquery) "{" :s* :select-query :s* "}"))

    :pattern-elem (choice :subquery :union-pattern :optional-pattern
                          :minus-pattern :filter :group-pattern :triples)

    # SELECT projection
    :count-expr (group (* (constant :count) "(" :s* :kw-count :s* "(" :s*
                          (? (group (* (constant :cdistinct) :kw-distinct :s+)))
                          :var :s* ")" :s* :kw-as :s+ :var :s* ")"))
    :proj-star (group (* (constant :star) "*"))
    :projection (group (* (constant :proj)
                          (some (* :s* (choice :count-expr :var :proj-star)))))

    # Solution modifiers
    :group-by (group (* (constant :groupby) :kw-group :s+ :kw-by :s+ :var))
    :order-by (group (* (constant :orderby) :kw-order :s+ :kw-by :s+
                        (choice
                          (group (* (constant :ord)
                                    (capture (choice :kw-asc :kw-desc))
                                    :s* "(" :s* :var :s* ")"))
                          (group (* (constant :ord) (constant "ASC") :var)))))
    :limit (group (* (constant :limit) :kw-limit :s+
                     (capture (some (range "09")))))

    :select-query (group (* (constant :select)
                            :kw-select
                            (? (group (* (constant :distinct) :s+ :kw-distinct)))
                            :s+ :projection :s*
                            (? (* :kw-where :s*))
                            :group-pattern
                            (any (* :s* (choice :group-by :order-by :limit)))))

    :main (* :s* (group (* (constant :query)
                           (any (* :prefix-decl :s*))
                           :select-query))
             :s* -1)})

(def sparql-peg (peg/compile sparql-grammar))

# ============================================================
# 4. AST helpers
# ============================================================
(defn tag [node] (when (indexed? node) (first node)))

(defn resolve-wd-id
  "Resolve a bare Wikidata ID (Q.../P...) explicitly in the 'wikidata'
   language, independent of the REPL's current .lang setting."
  [id]
  (zelph/resolve id "wikidata"))

(defn strip-wd-iri
  "Strip well-known Wikidata IRI prefixes and resolve the (possibly
   name-prefixed) ID in the 'wikidata' language (returns a zelph/node).
   Non-Wikidata IRIs are returned unchanged as strings and act as node
   names resolved in the current language."
  [iri]
  (var resolved nil)
  (each [iri-pfx name-pfx] wd-iri-prefixes
    (when (and (nil? resolved) (string/has-prefix? iri-pfx iri))
      (set resolved
           (resolve-wd-id (string name-pfx (string/slice iri (length iri-pfx)))))))
  (if resolved resolved iri))

(defn as-node
  "Coerce a concrete term to a zelph/node: strings are resolved in the
   current language, nodes pass through unchanged."
  [v]
  (if (string? v) (zelph/resolve v) v))

(defn resolve-term
  "Convert a parsed term AST node into [:var name], a zelph/node (for
   Wikidata-prefixed terms, explicitly bound to the 'wikidata' language),
   or a plain string resolved later in the current language."
  [node prefixes]
  (case (tag node)
    :var [:var (node 1)]
    :iri (strip-wd-iri (node 1))
    :pname (do
             (def pfx (node 1))
             (def local (node 2))
             (def wd-pfx (get wikidata-prefixes pfx))
             (cond
               wd-pfx (resolve-wd-id (string wd-pfx local))
               # Declared prefixes expand to the full IRI, which is then
               # subject to the same Wikidata mapping as direct IRIs.
               (get prefixes pfx) (strip-wd-iri (string (get prefixes pfx) local))
               (string pfx ":" local)))
    :literal (node 1)
    :number (node 1)
    (error (string "Unsupported term: " (string/format "%q" node)))))

(defn parse-count-spec
  "Decompose a :count AST node into [counted-var alias distinct?].
   Shapes: [:count [:var c] [:var alias]]
           [:count [:cdistinct] [:var c] [:var alias]]"
  [cs]
  (def parts (slice cs 1))
  (def dist? (= (tag (first parts)) :cdistinct))
  (def vars (filter (fn [p] (= (tag p) :var)) parts))
  [((vars 0) 1) ((vars 1) 1) dist?])

(defn resolve-path-elem
  "Returns [pred-name modifier] where modifier is nil, \"+\" or \"*\"."
  [pelem prefixes]
  (def pred (resolve-term (pelem 1) prefixes))
  (def modifier (when (> (length pelem) 2) (pelem 2)))
  (when (= (tag pred) :var)
    (error "Variables are not allowed inside property paths"))
  [pred modifier])

# ============================================================
# 5. Binding-set utilities (solution sequences)
# ============================================================
# A solution is a Janet table mapping variable-name strings to zelph/node
# values (or plain strings for literals). A solution sequence is an array
# of such tables.

(defn compatible? [s1 s2]
  (var ok true)
  (eachp [k v] s1
    (when-let [v2 (get s2 k)]
      (unless (= v v2) (set ok false))))
  ok)

(defn merge-solutions [s1 s2]
  (def out (table/clone s1))
  (eachp [k v] s2 (put out k v))
  out)

(defn- solution-keys [sols]
  (def ks @{})
  (each s sols (eachp [k _] s (put ks k true)))
  ks)

(defn- common-vars
  "Sorted array of variable names occurring on both sides."
  [seq1 seq2]
  (def k1 (solution-keys seq1))
  (def k2 (solution-keys seq2))
  (def common (seq [k :keys k1 :when (get k2 k)] k))
  (sort common)
  common)

(defn- all-bound? [sols vars]
  (var ok true)
  (each s sols
    (each k vars
      (when (nil? (get s k)) (set ok false))))
  ok)

(defn node-key
  "Stable comparison/dedup key: wikidata ID if available, else any name,
   else the value's printed form."
  [v]
  (cond
    (nil? v) ""
    (string? v) v
    (or (zelph/name v "wikidata") (zelph/name v) (string/format "%q" v))))

(defn- sol-key-fn
  "Returns a function mapping a solution to a hashable join key over the
   given (sorted, non-empty) common variables. For a single variable the
   bound value itself is the key - the zelph/node abstract type hashes and
   compares by node id, so this needs no name lookups and cannot collide.
   For multiple variables a string signature via node-key is used."
  [vars]
  (if (= 1 (length vars))
    (let [k (first vars)]
      (fn [s] (get s k)))
    (fn [s] (string/join (map (fn [k] (node-key (get s k))) vars) "\x01"))))

(defn join
  "Natural join of two solution sequences. Hash join over the shared
   variables when every row binds all of them (the supported query class
   always does); the quadratic nested loop remains as fallback, which also
   covers compatibility-via-absence for ragged rows."
  [seq1 seq2]
  (if (or (empty? seq1) (empty? seq2))
    @[]
    (do
      (def common (common-vars seq1 seq2))
      (cond
        # No shared variables: full cross product (as before)
        (empty? common)
        (do
          (def out @[])
          (each a seq1
            (each b seq2
              (array/push out (merge-solutions a b))))
          out)

        (and (all-bound? seq1 common) (all-bound? seq2 common))
        (do
          (def keyf (sol-key-fn common))
          (def buckets @{})
          (each b seq2
            (def key (keyf b))
            (def bucket (or (get buckets key) @[]))
            (array/push bucket b)
            (put buckets key bucket))
          (def out @[])
          (each a seq1
            (each b (or (get buckets (keyf a)) [])
              (array/push out (merge-solutions a b))))
          out)

        # Fallback: nested loop
        (do
          (def out @[])
          (each a seq1
            (each b seq2
              (when (compatible? a b)
                (array/push out (merge-solutions a b)))))
          out)))))

(defn left-join
  "OPTIONAL semantics: keep all of seq1, extend with compatible seq2 rows."
  [seq1 seq2]
  (def common (if (empty? seq2) @[] (common-vars seq1 seq2)))
  (cond
    (empty? seq2)
    (array ;seq1)

    (and (not (empty? common)) (all-bound? seq1 common) (all-bound? seq2 common))
    (do
      (def keyf (sol-key-fn common))
      (def buckets @{})
      (each b seq2
        (def key (keyf b))
        (def bucket (or (get buckets key) @[]))
        (array/push bucket b)
        (put buckets key bucket))
      (def out @[])
      (each a seq1
        (def bucket (get buckets (keyf a)))
        (if (or (nil? bucket) (empty? bucket))
          (array/push out a)
          (each b bucket (array/push out (merge-solutions a b)))))
      out)

    # No shared vars, or ragged bindings: nested loop (original semantics)
    (do
      (def out @[])
      (each a seq1
        (var extended false)
        (each b seq2
          (when (compatible? a b)
            (set extended true)
            (array/push out (merge-solutions a b))))
        (unless extended (array/push out a)))
      out)))

(defn shares-bound-var? [a b]
  (var found false)
  (eachp [k _] b
    (unless (nil? (get a k)) (set found true)))
  found)

(defn minus-join
  "MINUS semantics: drop seq1 rows that are compatible with some seq2 row
   sharing at least one bound variable. Hash-based O(n+m) when every row
   binds all shared variables; quadratic fallback otherwise."
  [seq1 seq2]
  (def common (if (or (empty? seq1) (empty? seq2)) @[] (common-vars seq1 seq2)))
  (cond
    # No shared variables (or nothing to subtract): nothing is removed
    (empty? common)
    (array ;seq1)

    (and (all-bound? seq1 common) (all-bound? seq2 common))
    (do
      (def keyf (sol-key-fn common))
      (def blocked @{})
      (each b seq2 (put blocked (keyf b) true))
      (filter (fn [a] (not (get blocked (keyf a)))) seq1))

    (filter
      (fn [a]
        (not (some (fn [b] (and (compatible? a b) (shares-bound-var? a b)))
                   seq2)))
      seq1)))

(defn distinct-solutions [sols vars]
  (def seen @{})
  (def out @[])
  (each s sols
    (def key (string/join (map (fn [v] (node-key (get s v))) vars) "\x01"))
    (unless (get seen key)
      (put seen key true)
      (array/push out s)))
  out)

# ============================================================
# 6. Evaluating triple patterns
# ============================================================
(defn term->query-arg
  "Convert a resolved term to a zelph/fact argument: bound value from the
   solution, quoted symbol for free variables, or concrete string/node.
   Free variables are recorded in var-syms."
  [term sol var-syms]
  (if (= (tag term) :var)
    (do
      (def name (term 1))
      (def bound (get sol name))
      (if (nil? bound)
        (do
          (def sym (symbol (string "V" name)))
          (put var-syms name sym)
          sym)
        bound))
    term))

(defn eval-bgp-block
  "Evaluate a set of simple (non-path) triples against existing partial
   solutions one solution at a time. A single triple with a concrete
   predicate and exactly one free end is answered by a direct adjacency
   lookup (zelph/targets / zelph/sources) - O(deg(node)) instead of a
   scan over all facts of the predicate per solution, no pattern facts
   are created in the graph and no engine caches are invalidated.
   Everything else goes through one conjunction query via the
   unification engine.
   triples: array of [s p o] resolved-term tuples."
  [triples solutions]
  (if (empty? triples)
    solutions
    (do
      (def out @[])

      (defn run-unification [sol args-per-triple var-syms]
        (def facts
          (map (fn [[s p o]] (zelph/fact s p o)) args-per-triple))
        (def pattern
          (if (= 1 (length facts))
            (first facts)
            (do
              (def cset (zelph/set ;facts))
              (zelph/fact cset "~" "conjunction")
              cset)))
        (def results (zelph/query pattern))
        (each r results
          (def merged (table/clone sol))
          (eachp [var-name sym] var-syms
            (def bound (get r sym))
            (when bound (put merged var-name bound)))
          (array/push out merged)))

      (defn push-binding [sol var-syms value]
        (def merged (table/clone sol))
        (eachp [var-name _] var-syms (put merged var-name value))
        (array/push out merged))

      (each sol solutions
        (def var-syms @{})
        (def args-per-triple
          (map (fn [[s p o]]
                 [(term->query-arg s sol var-syms)
                  (term->query-arg p sol var-syms)
                  (term->query-arg o sol var-syms)])
               triples))
        (if (empty? var-syms)
          # Fully bound: pure existence check, no graph mutation
          (when (all (fn [[s p o]] (zelph/exists s p o)) args-per-triple)
            (array/push out sol))
          (do
            (def fast
              (and (= 1 (length args-per-triple))
                   (= 1 (length var-syms))
                   (let [[s p o] (first args-per-triple)]
                     (and (not (symbol? p))
                          (not= (symbol? s) (symbol? o))))))
            (if fast
              (let [[s p o] (first args-per-triple)]
                (if (symbol? o)
                  (each tgt (zelph/targets s p)
                    (push-binding sol var-syms tgt))
                  (each src (zelph/sources p o)
                    (push-binding sol var-syms src))))
              (run-unification sol args-per-triple var-syms)))))
      out)))

(defn closure-set
  "Build a membership table from a closure array. Keys are the zelph/node
   values themselves: the zelph/node abstract type defines hash and compare,
   so distinct wrappers of the same node compare equal."
  [arr]
  (def tbl @{})
  (each n arr (put tbl n true))
  tbl)

(defn eval-path-step
  "Evaluate one transitive path step  subj --pred(+|*)--> obj  against a
   solution sequence. Closures for constant endpoints are computed exactly
   once and shared across all solutions; bound variables are checked via
   set membership instead of per-solution closures."
  [s pred modifier o solutions]
  (def include-start (= modifier "*"))
  (def out @[])
  (def s-const (when (not= (tag s) :var) s))
  (def o-const (when (not= (tag o) :var) o))

  (cond
    # --- Object is constant: one backward closure for all solutions ---
    (not (nil? o-const))
    (do
      (def reach (zelph-closure-sources (as-node o-const) pred include-start))
      (def reach-set (closure-set reach))
      (def s-fixed (when s-const (as-node s-const)))
      (each sol solutions
        (def s-val (or s-fixed (get sol (s 1))))
        (if (nil? s-val)
          (each src reach
            (def merged (table/clone sol))
            (put merged (s 1) src)
            (array/push out merged))
          (when (get reach-set s-val)
            (array/push out sol)))))

    # --- Subject is constant: one forward closure for all solutions ---
    (not (nil? s-const))
    (do
      (def reach (zelph-closure (as-node s-const) pred include-start))
      (def reach-set (closure-set reach))
      (each sol solutions
        (def o-val (get sol (o 1)))
        (if (nil? o-val)
          (each tgt reach
            (def merged (table/clone sol))
            (put merged (o 1) tgt)
            (array/push out merged))
          (when (get reach-set o-val)
            (array/push out sol)))))

    # --- Both ends are variables: per-solution, memoized by bound node ---
    (do
      (def memo @{})
      (defn cached [fwd node]
        (def key [fwd node])
        (or (get memo key)
            (let [arr (if fwd
                        (zelph-closure node pred include-start)
                        (zelph-closure-sources node pred include-start))
                  entry [arr (closure-set arr)]]
              (put memo key entry)
              entry)))
      (each sol solutions
        (def s-val (get sol (s 1)))
        (def o-val (get sol (o 1)))
        (cond
          (not (nil? s-val))
          (do
            (def [arr aset] (cached true s-val))
            (if (nil? o-val)
              (each tgt arr
                (def merged (table/clone sol))
                (put merged (o 1) tgt)
                (array/push out merged))
              (when (get aset o-val)
                (array/push out sol))))

          (not (nil? o-val))
          (do
            (def [arr _aset] (cached false o-val))
            (each src arr
              (def merged (table/clone sol))
              (put merged (s 1) src)
              (array/push out merged)))

          # Both unbound in this solution: enumerate all subjects that
          # actually carry the predicate, then take the forward closure of
          # each. Refused for `*`, where every node trivially reaches itself.
          (do
            (when include-start
              (error "Property path with both ends unbound is not supported for *"))
            (def pairs (zelph/query (zelph/fact 'PATHSUBJ pred 'PATHOBJ)))
            (def subj-seen @{})
            (each r pairs
              (def subj (get r 'PATHSUBJ))
              (unless (or (nil? subj) (get subj-seen subj))
                (put subj-seen subj true)
                (each tgt (zelph-closure subj pred false)
                  (def merged (table/clone sol))
                  (put merged (s 1) subj)
                  (put merged (o 1) tgt)
                  (array/push out merged)))))))))
  out)

(defn step-candidates
  "Compute the candidate node set for the variable end of a transitive
   step whose other end is constant. Returns [arr membership-set]."
  [st]
  (def [s pred modifier o] st)
  (def include (= modifier "*"))
  (def arr
    (if (= (tag s) :var)
      (zelph-closure-sources (as-node o) pred include)
      (zelph-closure (as-node s) pred include)))
  [arr (closure-set arr)])

(defn eval-step-group
  "Conjunction of transitive steps that all bind the same still-unbound
   variable from a constant end, e.g. the disjointness query shape
     ?class wdt:P279+ wd:A .  ?class wdt:P279+ wd:B .
   Every closure is computed exactly once; only the smallest closure is
   enumerated, the others act as membership filters. This avoids
   materializing solution rows for the larger closures."
  [var-name group-steps solutions]
  (def closures (map step-candidates group-steps))
  (var min-i 0)
  (eachp [i c] closures
    (when (< (length (c 0)) (length ((closures min-i) 0)))
      (set min-i i)))
  (def base-arr ((closures min-i) 0))
  (def other-sets
    (seq [i :range [0 (length closures)] :when (not= i min-i)]
      ((closures i) 1)))
  (def out @[])
  (each sol solutions
    (each cand base-arr
      (when (all (fn [cset] (get cset cand)) other-sets)
        (def merged (table/clone sol))
        (put merged var-name cand)
        (array/push out merged))))
  out)

(def fresh-counter @[0])
(defn fresh-var []
  (put fresh-counter 0 (inc (get fresh-counter 0)))
  [:var (string "__path" (get fresh-counter 0))])

(defn expand-path
  "Expand a path AST (sequence of elements, each optionally +/*) between
   subject s and object o into simple triples and transitive steps,
   introducing fresh intermediate variables for sequence paths.
   Returns [simple-triples path-steps]."
  [s path-node o prefixes]
  (def elems (slice path-node 1))
  (def simple @[])
  (def steps @[])
  (var current-subj s)
  (eachp [i pelem] elems
    (def [pred modifier] (resolve-path-elem pelem prefixes))
    (def is-last (= i (dec (length elems))))
    (def current-obj (if is-last o (fresh-var)))
    (if (nil? modifier)
      (array/push simple [current-subj pred current-obj])
      (array/push steps [current-subj pred modifier current-obj]))
    (set current-subj current-obj))
  [simple steps])

# ============================================================
# 7. FILTER evaluation
# ============================================================
(defn operand-value [op sol prefixes]
  (case (tag op)
    :var (node-key (get sol (op 1)))
    :func (do
            (def fname (string/ascii-lower (op 1)))
            (def var-name ((op 2) 1))
            (def val (get sol var-name))
            (case fname
              "str" (node-key val)
              # Language tags are not modelled in zelph; lang() yields "".
              # FILTER (lang(?x) = "en") therefore never matches - labels
              # are handled via zelph/name in the output layer instead.
              "lang" ""
              (error (string "Unsupported function in FILTER: " fname))))
    :literal (op 1)
    :number (op 1)
    :iri (node-key (resolve-term op prefixes))
    :pname (node-key (resolve-term op prefixes))
    (error "Unsupported FILTER operand")))

(defn numeric? [s]
  (and (string? s)
       (peg/match '(* (? "-") (some (range "09"))
                      (? (* "." (some (range "09")))) -1)
                  s)))

(defn eval-filter [filter-node prefixes solutions]
  (def expr (filter-node 1))
  (def [_ left op right] expr)
  (filter
    (fn [sol]
      (def lv (operand-value left sol prefixes))
      (def rv (operand-value right sol prefixes))
      (def [l r]
        (if (and (numeric? lv) (numeric? rv))
          [(scan-number lv) (scan-number rv)]
          [(string lv) (string rv)]))
      (case op
        "=" (= l r)
        "!=" (not= l r)
        "<" (< l r)
        ">" (> l r)
        "<=" (<= l r)
        ">=" (>= l r)
        false))
    solutions))

# ============================================================
# 8. Group graph pattern evaluation
# ============================================================
# Forward declarations (mutually recursive: group <-> union <-> select)
(var eval-group-impl nil)
(var eval-union-impl nil)
(var eval-select-impl nil)

(defn eval-group [group-node prefixes solutions]
  (eval-group-impl group-node prefixes solutions))
(defn eval-union [union-node prefixes solutions]
  (eval-union-impl union-node prefixes solutions))
(defn eval-select [select-node prefixes]
  (eval-select-impl select-node prefixes))

(set eval-union-impl
  (fn [union-node prefixes solutions]
    (def out @[])
    (each grp (slice union-node 1)
      (each s (eval-group grp prefixes solutions)
        (array/push out s)))
    out))

(set eval-group-impl
  (fn [group-node prefixes solutions]
    (var sols solutions)
    # Consecutive simple triples are batched into one conjunction query;
    # transitive path steps are applied right after their batch.
    (def pending-triples @[])
    (def pending-steps @[])

    # A path step is executable when at least one end is constant or already
    # bound in some solution. Steps whose ends are both unbound are deferred,
    # because earlier steps may bind their variables first. Needed e.g. for
    # example query (7):  ?c P279* ?m  combined with  ?c P279*/P31/P279* ?m -
    # the P31 triple and the closures around it bind ?c and ?m, after which
    # the first (initially both-unbound) step becomes a plain check.
    (defn step-side-bound? [t]
      (or (not= (tag t) :var)
          (some (fn [sol] (not (nil? (get sol (t 1))))) sols)))

    (defn flush-pending []
      (unless (and (empty? pending-triples) (empty? pending-steps))
        (def triple-count (length pending-triples))
        (set sols (prof (string "bgp " triple-count " triple(s) over " (length sols) " sol(s)")
                        (fn [] (eval-bgp-block pending-triples sols))))
        (def steps (array ;pending-steps))

        # --- Closure-intersection optimization ---
        # Steps that bind the same still-unbound variable from a constant
        # end are evaluated as one group via eval-step-group: enumerate
        # the smallest closure, filter through the others.
        (def var-groups @{})
        (eachp [i st] steps
          (def [s _pred _mod o] st)
          (def var-end
            (cond
              (and (= (tag s) :var) (not= (tag o) :var)) s
              (and (= (tag o) :var) (not= (tag s) :var)) o
              nil))
          (when (and var-end (not (step-side-bound? var-end)))
            (def key (var-end 1))
            (def bucket (or (get var-groups key) @[]))
            (array/push bucket i)
            (put var-groups key bucket)))

        (def consumed @{})
        (eachp [var-name idxs] var-groups
          (when (> (length idxs) 1)
            (def group-steps (map (fn [i] (steps i)) idxs))
            (set sols (prof (string "closure-intersection ?" var-name
                                    " (" (length idxs) " steps)")
                            (fn [] (eval-step-group var-name group-steps sols))))
            (each i idxs (put consumed i true))))

        (def remaining @[])
        (eachp [i st] steps
          (unless (get consumed i) (array/push remaining st)))

        (while (> (length remaining) 0)
          (var idx nil)
          (eachp [i st] remaining
            (when (and (nil? idx)
                       (or (step-side-bound? (st 0)) (step-side-bound? (st 3))))
              (set idx i)))
          # No executable step found: fall back to the first one, whose
          # both-ends-unbound handling enumerates (+) or rejects (*).
          (when (nil? idx) (set idx 0))
          (def [s pred modifier o] (remaining idx))
          (set sols (prof (string "path-step over " (length sols) " sol(s)")
                          (fn [] (eval-path-step s pred modifier o sols))))
          (array/remove remaining idx))
        (array/clear pending-triples)
        (array/clear pending-steps)))

    (each elem (slice group-node 1)
      (case (tag elem)
        :triples
        (do
          (def subj (resolve-term (elem 1) prefixes))
          (each pp (slice elem 2)
            (def verb (pp 1))
            (def objs (slice (pp 2) 1))
            (each obj-ast objs
              (def obj (resolve-term obj-ast prefixes))
              (if (= (tag verb) :var)
                (array/push pending-triples [subj [:var (verb 1)] obj])
                (do
                  (def [simple steps] (expand-path subj verb obj prefixes))
                  (each t simple (array/push pending-triples t))
                  (each st steps (array/push pending-steps st)))))))

        :filter
        (do (flush-pending)
            (set sols (eval-filter elem prefixes sols)))

        :optional
        (do (flush-pending)
            # Correlated evaluation: the inner pattern is seeded with the
            # current solutions, so bound variables (e.g. ?x) restrict the
            # search instead of enumerating the whole graph. Equivalent
            # results for shared-variable patterns, vastly cheaper on large
            # graphs.
            (def inner (elem 1))
            (def opt-sols
              (prof (string "optional inner (" (length sols) " seeds)")
                    (fn []
                      (if (= (tag inner) :union)
                        (eval-union inner prefixes sols)
                        (eval-group inner prefixes sols)))))
            (set sols (prof (string "left-join " (length sols) "x" (length opt-sols))
                            (fn [] (left-join sols opt-sols)))))

        :minus
        (do (flush-pending)
            # Correlated evaluation (seeded with current solutions). This
            # gives FILTER NOT EXISTS semantics: a row is dropped when it
            # can be extended to satisfy the pattern. Strict SPARQL MINUS
            # differs only when the group shares no variables with the
            # outer pattern - a case the supported query class never uses,
            # and independent evaluation would enumerate the whole graph.
            (def m-sols (prof (string "minus inner (" (length sols) " seeds)")
                              (fn [] (eval-group (elem 1) prefixes sols))))
            (set sols (prof (string "minus-join " (length sols) "x" (length m-sols))
                            (fn [] (minus-join sols m-sols)))))

        :union
        (do (flush-pending)
            # Each branch is seeded with the current solutions (correlated),
            # so the per-branch results are already joined - no cross join
            # against an independent enumeration needed.
            (set sols (eval-union elem prefixes sols)))

        :group
        (do (flush-pending)
            (set sols (eval-group elem prefixes sols)))

        :subquery
        (do (flush-pending)
            (def [sub-sols _] (eval-select (elem 1) prefixes))
            (set sols (prof (string "subquery join " (length sols) "x" (length sub-sols))
                            (fn [] (join sols sub-sols)))))

        (error (string "Unsupported pattern element: "
                       (string/format "%q" (tag elem))))))
    (flush-pending)
    sols))

# ============================================================
# 9. SELECT evaluation (projection, modifiers)
# ============================================================
(set eval-select-impl
  (fn [select-node prefixes]
    (var distinct? false)
    (var projection nil)
    (var group-pattern nil)
    (var group-by nil)
    (var order-by nil)
    (var limit nil)

    (each part (slice select-node 1)
      (case (tag part)
        :distinct (set distinct? true)
        :proj (set projection part)
        :group (set group-pattern part)
        :groupby (set group-by ((part 1) 1))
        :orderby (set order-by (part 1))
        :limit (set limit (scan-number (part 1)))
        nil))

    (var sols (eval-group group-pattern prefixes @[@{}]))

    # --- GROUP BY + COUNT ---
    (def count-specs
      (filter (fn [p] (= (tag p) :count)) (slice projection 1)))
    (when (or group-by (not (empty? count-specs)))
      (def groups @{})
      (each s sols
        (def key (if group-by (node-key (get s group-by)) :all))
        (def bucket (or (get groups key) @[]))
        (array/push bucket s)
        (put groups key bucket))
      (def grouped @[])
      (eachp [_ bucket] groups
        (def rep (table/clone (first bucket)))
        (each cs count-specs
          (def [cvar alias dist?] (parse-count-spec cs))
          (def n
            (if dist?
              (do
                (def seen @{})
                (each s bucket
                  (def v (get s cvar))
                  (unless (nil? v) (put seen (node-key v) true)))
                (length seen))
              (length bucket)))
          (put rep alias (string n)))
        (array/push grouped rep))
      # SPARQL semantics: an aggregate without GROUP BY over an empty
      # solution sequence yields a single row with COUNT = 0.
      (when (and (empty? grouped) (nil? group-by))
        (def rep @{})
        (each cs count-specs
          (def [_ alias _] (parse-count-spec cs))
          (put rep alias "0"))
        (array/push grouped rep))
      (set sols grouped))

    # --- Projected variable list ---
    (def proj-vars
      (if (some (fn [p] (= (tag p) :star)) (slice projection 1))
        (do
          (def all-vars @{})
          (each s sols
            (eachp [k _] s
              (unless (string/has-prefix? "__path" k)
                (put all-vars k true))))
          (sorted (keys all-vars)))
        (do
          (def vars @[])
          (each p (slice projection 1)
            (case (tag p)
              :var (array/push vars (p 1))
              :count (array/push vars ((parse-count-spec p) 1))
              nil))
          vars)))

    # --- ORDER BY ---
    # Note: order-by already holds the inner [:ord dir var] tuple, because
    # the dispatch loop above stores (part 1).
    (when order-by
      (def dir (string/ascii-upper (order-by 1)))
      (def var-name ((order-by 2) 1))
      (set sols
        (sorted sols
          (fn [a b]
            (def av (node-key (get a var-name)))
            (def bv (node-key (get b var-name)))
            (def [x y]
              (if (and (numeric? av) (numeric? bv))
                [(scan-number av) (scan-number bv)]
                [(string av) (string bv)]))
            (if (= dir "DESC") (> x y) (< x y))))))

    # --- DISTINCT ---
    (when distinct?
      (set sols (distinct-solutions sols proj-vars)))

    # --- LIMIT ---
    (when (and limit (> (length sols) limit))
      (set sols (array/slice sols 0 limit)))

    # --- Projection: drop unprojected bindings ---
    (def projected @[])
    (each s sols
      (def row @{})
      (each v proj-vars (put row v (get s v)))
      (array/push projected row))
    [projected proj-vars]))

# ============================================================
# 10. Output formatting
# ============================================================
(defn display-value [v]
  (cond
    (nil? v) ""
    (string? v) v
    (do
      (def id (zelph/name v "wikidata"))
      (def label (or (zelph/name v "en") (zelph/name v)))
      (cond
        (and id label (not= id label)) (string id " (" label ")")
        (or id label (string/format "%q" v))))))

(defn format-results
  "Build the result text. Returned (not printed) so that the C++ keyword
   dispatcher can emit it through zelph's output handler - this is what
   makes the output visible to OutputCollector-based tests."
  [projected proj-vars]
  (if (empty? projected)
    "No results."
    (do
      (def lines @[])
      (array/push lines
        (string/join (map (fn [v] (string "?" v)) proj-vars) "\t"))
      (each row projected
        (array/push lines
          (string/join (map (fn [v] (display-value (get row v)))
                            proj-vars)
                       "\t")))
      (array/push lines
        (string/format "-- %d result(s) --" (length projected)))
      (string/join lines "\n"))))

# ============================================================
# 11. Top-level handler + keyword registration
# ============================================================
(def unsupported-keywords
  ["BIND" "VALUES" "SERVICE" "CONSTRUCT" "DESCRIBE" "GRAPH" "HAVING"])

(defn check-unsupported [text]
  (def upper (string/ascii-upper text))
  (each kw unsupported-keywords
    (when (string/find kw upper)
      (error (string "SPARQL feature not supported by this subset: " kw)))))

(defn sparql-incomplete?
  "Completeness check for the keyword dispatcher's veto protocol. A single
   blank line asks the handler whether the accumulated text is complete;
   returning :incomplete resumes accumulation, so blank lines inside pasted
   queries (e.g. between the PREFIX prologue and SELECT) are harmless. Two
   consecutive blank lines force dispatch.
   Incomplete while: no SELECT seen yet (prologue phase), no opening brace
   yet, or braces unbalanced. Braces inside string literals or comments are
   not excluded - acceptable for the supported query class."
  [text]
  (def upper (string/ascii-upper text))
  (or (nil? (string/find "SELECT" upper))
      (nil? (string/find "{" text))
      (do
        (var depth 0)
        (each b text
          (case b
            123 (++ depth)    # {
            125 (-- depth)))  # }
        (not= depth 0))))

(defn sparql-handler [text]
  (if (sparql-incomplete? text)
    :incomplete
    (do
      (check-unsupported text)
      (table/clear closure-cache)
      (def parsed (peg/match sparql-peg text))
      (unless parsed
        (error (string "SPARQL syntax error or unsupported construct. Subset: "
                       "SELECT [DISTINCT] / WHERE, BGPs, property paths (+ * /), "
                       "OPTIONAL, MINUS, UNION, FILTER comparisons, subqueries, "
                       "GROUP BY + COUNT [DISTINCT], ORDER BY, LIMIT")))
      (def query-node (first parsed))

      (def prefixes @{})
      (var select-node nil)
      (each part (slice query-node 1)
        (case (tag part)
          :prefix (put prefixes (part 1) (part 2))
          :select (set select-node part)))

      (def [projected proj-vars]
        (prof "total eval" (fn [] (eval-select select-node prefixes))))
      (format-results projected proj-vars))))

(zelph/register-keyword "sparql" sparql-handler)

"SPARQL subset loaded. Type 'sparql', paste your query, finish with an empty line."
%